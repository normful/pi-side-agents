{
	"name": "pi-side-agents",
	"version": "1.1.0",
	"description": "Side-agent orchestration for Pi — spin off parallel child agents in tmux windows and git worktrees.",
	"license": "MIT",
	"type": "module",
	"keywords": [
		"pi",
		"pi-coding-agent",
		"pi-package",
		"parallel",
		"agent",
		"subagent",
		"tmux",
		"worktree"
	],
	"files": [
		"extensions/",
		"skills/",
		"docs/",
		"README.md"
	],
	"pi": {
		"extensions": [
			"./extensions"
		],
		"skills": [
			"./skills"
		]
	},
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"typecheck": "bun run tsc --noEmit 2>&1 | grep -m 1 '^'",
		"biomeformat": "biome format --write --colors=off --max-diagnostics=0",
		"biomelint": "biome lint --write --colors=off --max-diagnostics=0",
		"biomecheck": "biome check --write --colors=off --max-diagnostics=0",
		"test:integration": "node --test --test-concurrency=1 tests/integration/side-agents.integration.test.mjs",
		"test:extensions": "bun test extensions/**/*.test.ts"
	},
	"peerDependencies": {
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-coding-agent": "*",
		"@sinclair/typebox": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@types/bun": "^1.3.11",
		"typescript": "^5.9.3"
	}
}
